# Development image: source is bind-mounted by docker-compose.dev.yml,
# uvicorn --reload picks up changes without a rebuild.
FROM python:3.12-slim

WORKDIR /srv/api

# See apps/api/Dockerfile (production) - same reasoning.
RUN apt-get update && apt-get install -y --no-install-recommends network-manager bluez \
    && rm -rf /var/lib/apt/lists/*

COPY apps/api/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
