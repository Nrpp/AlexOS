# AlexOS API
ALEXOS_ENV=development
ALEXOS_API_HOST=0.0.0.0
ALEXOS_API_PORT=8000
ALEXOS_DATABASE_URL=sqlite+aiosqlite:///./alexos.db
ALEXOS_CORS_ORIGINS=http://localhost:5173

# AlexOS Web
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# modules/room - Home Assistant (see modules/room/README.md to generate a token)
HA_BASE_URL=
HA_ACCESS_TOKEN=

# Gmail (modules/communication), Calendar (modules/calendar), Tasks
# (modules/tasks) - shared Google OAuth client. Run
# scripts/google_oauth_setup.py once to get all three values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# modules/focus - outbound webhook(s) fired on focus start/end so other
# devices can enter Do Not Disturb (see modules/focus/README.md).
# Comma-separated if you have more than one device.
FOCUS_WEBHOOK_URLS=
